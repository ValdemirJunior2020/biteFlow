# Firebase Web App config
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xxxxxxxx
EXPO_PUBLIC_FIREBASE_APP_ID=1:xxxxxxxx:web:xxxxxxxx
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google auth client IDs
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Stripe publishable key for the app
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Firebase Functions / API base URL
EXPO_PUBLIC_API_BASE_URL=https://us-central1-your-project.cloudfunctions.net/api

# Google Maps SDK keys
EXPO_PUBLIC_IOS_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_ANDROID_GOOGLE_MAPS_API_KEY=

# Optional: RevenueCat
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# Super admin login email for your platform account
EXPO_PUBLIC_SUPER_ADMIN_EMAIL=you@example.com
